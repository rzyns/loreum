# Loreum homelab Docker Compose settings.
# Copy to .env.homelab and replace every placeholder before deploying.
# Keep .env.homelab out of git.

# Image/build controls
LOREUM_IMAGE_TAG=local
CONTAINER_SUFFIX=
LOREUM_ENV_FILE=.env.homelab

# Host bind addresses. Defaults are loopback-only so a reverse proxy can be the public edge.
WEB_BIND_ADDR=127.0.0.1
WEB_PORT=3020
API_BIND_ADDR=127.0.0.1
API_PORT=3021
MCP_BIND_ADDR=127.0.0.1
DB_BIND_ADDR=127.0.0.1
DB_PORT=5432
REDIS_BIND_ADDR=127.0.0.1
REDIS_PORT=6379

# Server-side API URL used by the web container to proxy same-origin /v1 requests.
# Browsers call the web origin's /v1/* route; the web container forwards internally here.
API_INTERNAL_URL=http://api:3021/v1

# Optional MCP HTTP deployment settings. Keep remote MCP read-only by default.
MCP_API_BASE_URL=http://api:3021/v1
MCP_API_TOKEN=replace-with-project-api-key
MCP_TRANSPORT=http
MCP_HTTP_PORT=3022
MCP_HTTP_AUTH_TOKEN=replace-with-generated-client-to-mcp-token
MCP_READ_ONLY=true
MCP_ENABLE_WRITES=false
MCP_WRITE_TOOLS=

# Database. Use a generated password in .env.homelab; do not commit it.
POSTGRES_USER=loreum
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
POSTGRES_DB=loreum

# API runtime
DATABASE_URL=postgresql://loreum:replace-with-a-long-random-postgres-password@postgres:5432/loreum
REDIS_URL=redis://redis:6379
CORS_ORIGIN=http://localhost:3020

# Authentication/session secrets. Replace with real deployment values.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_TTL=15m
TOKEN_ROTATION_MINUTES=100
SESSION_TTL_DAYS=30
# Use your parent domain for subdomain deployments, e.g. .example.internal.
# Leave blank for direct localhost/staging tests.
COOKIE_DOMAIN=

# Auth providers. Local email/password auth is enabled by default.
AUTH_LOCAL_ENABLED=true
AUTH_GOOGLE_ENABLED=false

# Optional Google OAuth. Only required when AUTH_GOOGLE_ENABLED=true.
# Configure the callback URL in Google Cloud to match your external API URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3021/v1/auth/google/callback

# Optional OpenSearch profile. Not required for the current basic Prisma-backed search path.
OPENSEARCH_BIND_ADDR=127.0.0.1
OPENSEARCH_PORT=19200
OPENSEARCH_DISABLE_SECURITY=true
OPENSEARCH_ADMIN_PASSWORD=replace-with-opensearch-admin-password
