# MCP local development settings.
# Copy to .env before starting apps/mcp.

MCP_API_BASE_URL=http://localhost:3021/v1
MCP_API_TOKEN=your-project-api-key

# Local stdio mode is the default. HTTP mode is intended for controlled
# deployments and must keep writes disabled unless every write-safety gate has
# been explicitly reviewed.
# MCP_TRANSPORT=stdio
# MCP_HTTP_PORT=3022
# MCP_HTTP_AUTH_TOKEN=replace-with-strong-random-token
# MCP_READ_ONLY=true

# HTTP MCP is read-only/fail-closed by default. MCP_READ_ONLY=false alone does
# not expose mutation tools over HTTP. Remote write exposure requires explicit
# opt-in plus an allowlist; currently only create_entity is supported.
# Do not enable it for remote deployments unless the Loreum API independently
# enforces target API-key permissions (READ_ONLY, DRAFT_WRITE, CANONICAL_WRITE;
# legacy READ_WRITE aliases CANONICAL_WRITE) and per-key project scoping.
# Any all-write HTTP MCP posture is staging-only for testworld, not production/default.
# MCP_ENABLE_WRITES=false
# MCP_WRITE_TOOLS=
