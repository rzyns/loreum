# API local development settings.
# Copy to .env before starting apps/api.

DATABASE_URL=postgresql://loreum:loreum_local_pw@localhost:5432/loreum
REDIS_URL=redis://localhost:6379
API_PORT=3021
CORS_ORIGIN=http://localhost:3020

JWT_SECRET=change_me_for_local_dev_only_32_chars
JWT_ACCESS_TTL=15m
TOKEN_ROTATION_MINUTES=100
SESSION_TTL_DAYS=30
COOKIE_DOMAIN=localhost

AUTH_LOCAL_ENABLED=true
AUTH_GOOGLE_ENABLED=false

# Optional Google OAuth. Only required when AUTH_GOOGLE_ENABLED=true.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3021/v1/auth/google/callback
